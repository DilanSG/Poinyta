# Variables de entorno para Poinyta Sync Server
# Copia este archivo como .env y completa los valores.

# API Key para autenticar el bridge de sincronizacion con n8n.
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POINYTA_API_KEY=

# SendGrid API Key para envio de reportes (free: 100 emails/dia)
# Crear en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Correo destino de los reportes (default: nalidess2002@gmail.com)
# REPORT_TO=nalidess2002@gmail.com

# --- Para la app (EXPO_PUBLIC_) ---
# URL del bridge (Render, local, etc.)
EXPO_PUBLIC_REPORT_URL=
# API Key del bridge (la misma que POINYTA_API_KEY)
EXPO_PUBLIC_REPORT_KEY=
